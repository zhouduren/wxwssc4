.summary {
  display: flex;
  gap: 16rpx;
}

.sum {
  flex: 1;
  background: #fff1e6;
  border-radius: 12rpx;
  padding: 16rpx;
}

.val {
  font-size: 32rpx;
  color: #fa8c16;
  font-weight: 600;
}

.lab {
  color: #888;
  margin-top: 6rpx;
}

.hot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f3f3f3;
}

.bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 10rpx 0;
}

.bar-left {
  width: 160rpx;
  color: #888;
}

.bar-right {
  flex: 1;
  position: relative;
  height: 28rpx;
  background: #fff1e6;
  border-radius: 14rpx;
}

.bar-fill {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  background: #fa8c16;
  border-radius: 14rpx;
}

.bar-val {
  position: absolute;
  right: 8rpx;
  top: -36rpx;
  font-size: 24rpx;
  color: #fa8c16;
}
