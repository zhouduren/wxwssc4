<view class="container" wx:if="{{detail}}">
  <view class="card">
    <view>订单号：{{detail.orderNo}}</view>
    <view>状态：<text class="tag tag-orange">{{detail.status}}</text></view>
    <view>用户：{{detail.nickname}} {{detail.phone}}</view>
    <view>地址：{{detail.deliveryAddress}}</view>
    <view>联系人：{{detail.contactName}} {{detail.contactPhone}}</view>
    <view>配送时间：{{detail.deliveryTime}}</view>
    <view>备注：{{detail.userRemark || '-'}}</view>
  </view>
  <view class="card">
    <view class="title">商品明细</view>
    <view class="line" wx:for="{{detail.items}}" wx:key="id">
      <view>{{item.productName}} x {{item.quantity}}</view>
      <view>￥{{item.subtotal}}</view>
    </view>
  </view>
  <button
    wx:if="{{detail.status==='待配送' || detail.status==='配送中'}}"
    class="btn btn-primary"
    bindtap="nextStatus"
  >{{detail.status==='待配送'?'标记配送中':'标记已完成'}}</button>
</view>
