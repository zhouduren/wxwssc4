<view class="container">
  <view class="card">
    <view class="title">{{editing?'编辑商品':'新增商品'}}</view>
    <input class="ipt" placeholder="名称" data-key="name" bindinput="onInput" value="{{form.name}}" />
    <picker mode="selector" range="{{categories}}" bindchange="onCategory">
      <view class="picker">分类：{{form.category}}</view>
    </picker>
    <input class="ipt" placeholder="价格" type="digit" data-key="price" bindinput="onInput" value="{{form.price}}" />
    <input class="ipt" placeholder="库存" type="number" data-key="stock" bindinput="onInput" value="{{form.stock}}" />
    <input class="ipt" placeholder="主图URL" data-key="imageUrl" bindinput="onInput" value="{{form.imageUrl}}" />
    <input class="ipt" placeholder="详情HTML" data-key="detailHtml" bindinput="onInput" value="{{form.detailHtml}}" />
    <input class="ipt" placeholder="上架状态 1/0" type="number" data-key="status" bindinput="onInput" value="{{form.status}}" />
    <button class="btn-primary" bindtap="submit">{{editing?'保存修改':'新增商品'}}</button>
  </view>
  <view class="card" wx:for="{{list}}" wx:key="id">
    <view class="row">
      <view>{{item.name}}（{{item.category}}）</view>
      <view class="tag {{item.status?'tag-orange':'tag-gray'}}">{{item.status?'上架':'下架'}}</view>
    </view>
    <view>￥{{item.price}} 库存:{{item.stock}} 销量:{{item.sales}}</view>
    <view class="row mt">
      <button class="btn btn-outline" size="mini" data-item="{{item}}" bindtap="edit">编辑</button>
      <button class="btn btn-primary" size="mini" data-item="{{item}}" bindtap="toggleStatus">{{item.status?'下架':'上架'}}</button>
      <button class="btn btn-outline" size="mini" data-id="{{item.id}}" bindtap="remove">删除</button>
    </view>
  </view>
</view>
