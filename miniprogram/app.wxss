page {
  background: #fff7e6;
  color: #333;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.btn-primary {
  background: #fa8c16;
  color: #fff;
}

.btn {
  border-radius: 999rpx;
  padding: 18rpx 28rpx;
}

.btn-outline {
  border: 1rpx solid #fa8c16;
  color: #fa8c16;
  background: transparent;
}

.tag {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.tag-orange {
  background: #fff1e6;
  color: #fa8c16;
}

.tag-green {
  background: #e6fffb;
  color: #13c2c2;
}

.tag-gray {
  background: #f5f5f5;
  color: #888;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}
